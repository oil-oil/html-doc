    {
      "id": "insights",
      "type": "evidenceBoard",
      "span": 6,
      "title": "洞察摘要",
      "items": [
        {
          "label": "01",
          "title": "HTML 的价值来自组织能力",
          "body": "分列、对比、流程、标注和交互，比长文更重要。"
        },
        {
          "label": "02",
          "title": "JSON 才是可审查源文件",
