    {
      "id": "diff",
      "type": "diffReview",
      "span": 8,
      "title": "Diff Review",
      "lines": [
        {
          "type": "remove",
          "text": "- <div class=\"card shadow-lg rounded-xl p-8\">"
        },
        {
          "type": "add",
          "text": "+ <section data-block=\"metric\" class=\"tile\">"
        },
        {
          "type": "add",
          "text": "+   <Metric value={data.value} spark={data.trend} />"
        },
        {
          "type": "neutral",
          "text": "  </section>"
        }
      ],
      "findings": [
        {
          "severity": "P1",
          "title": "组件替代样式堆叠",
          "body": "保留语义数据，避免重复生成视觉细节。"
        },
        {
          "severity": "P2",
          "title": "降低 DOM 嵌套",
          "body": "单个 block 直接承载布局，不再卡片套卡片。"
