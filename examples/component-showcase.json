        },
        {
          "label": "DESIGN",
          "title": "人文感字体",
          "body": "标题使用 Optima / Avenir Next，中文回退到苹方和霞鹜文楷。"
        },
        {
          "label": "RULE",
          "title": "文字尽量少",
          "body": "正文保持轻量；需要细节时交给矩阵、批注或展开材料。"
        },
        {
          "label": "HTML",
          "title": "充分利用水平空间",
          "body": "12 栏 span 机制，支持 4/8、6/6、8/4 分列。"
        }
      ]
    },
    {
      "id": "kanban",
      "type": "kanban",
      "span": 12,
      "title": "Kanban",
      "body": "横向分组清单，适合风险桶、任务桶、审查桶和反馈桶。",
      "columns": [
        {
          "title": "客户信任风险",
          "icon": "!",
          "tone": "danger",
          "items": [
            "未经搜索就确认品牌事实",
            "连续追问多个 intake 字段",
            {
              "title": "对进度事件输出内部 `stage` 名",
              "done": true
            },
            "承诺还没有 finalizer 生成的链接"
          ]
        },
        {
          "title": "成本与重复风险",
          "icon": "$",
          "tone": "warning",
          "items": [
            "未得到 yes/no 就启动 async run",
            "有旧 job 仍然重跑",
            "身份确认和参数确认混成一轮",
            {
              "title": "mock 路径被误报成生产通过",
              "tone": "accent"
            }
          ]
        },
        {
          "title": "资源一致性风险",
          "icon": "#",
          "tone": "info",
          "items": [
            "`product_id` 放进 payload 而不是 top-level",
            "`job_type` 没核实就当研究 job",
            "导出结果缺少上游任务 id",
            "旧发布能力被当成当前能力"
          ]
        }
      ]
    },
