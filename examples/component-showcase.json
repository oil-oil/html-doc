    {
      "id": "flow",
      "type": "flow",
      "span": 8,
      "title": "生成流程",
      "nodes": [
        {
          "label": "需求",
          "note": "代码、数据、问题"
        },
        {
          "label": "JSON",
          "note": "意图和结构"
        },
        {
          "label": "Renderer",
          "note": "组件组合"
        },
        {
          "label": "HTML",
          "note": "可读可交互"
        }
      ]
    },
    {
      "id": "decision",
      "type": "decisionTree",
      "span": 4,
      "title": "组件选择",
      "items": [
        {
          "level": 0,
          "condition": "需要解释过程",
          "result": "使用 flow 或 timeline"
        },
        {
          "level": 1,
          "condition": "有代码变化",
          "result": "使用 diffReview"
        },
        {
          "level": 1,
          "condition": "有多个方案",
          "result": "使用 variantGrid 或 matrix"
        },
        {
          "level": 0,
          "condition": "需要用户调整",
          "result": "使用 sliderLab、formEditor 或 promptEditor"
        }
      ]
    },
    {
      "id": "matrix",
      "type": "matrix",
      "span": 12,
      "title": "Decision Matrix",
      "body": "表格先显示对象、结论和风险，长证据放进展开详情。",
      "search": true,
      "sortable": true,
      "filters": [
        {
          "key": "risk",
          "label": "Risk",
          "options": [
            "High",
            "Medium",
            "Low"
