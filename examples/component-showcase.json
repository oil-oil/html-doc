      "items": [
        {
          "label": "TOKENS",
          "value": "-38%",
          "note": "JSON 替代重复 HTML",
          "spark": [
            8,
            7,
            7,
            5,
            4,
            3,
            3
          ]
        },
        {
          "label": "READ",
          "value": "2.4x",
          "note": "扫读速度提升",
          "spark": [
            2,
            3,
            4,
            6,
            7,
            8,
            9
          ]
        },
        {
          "label": "UI",
          "value": "17",
          "note": "内置组件",
          "spark": [
            3,
            3,
            4,
            6,
            8,
            12,
            17
