      "rows": [
        {
          "group": "需要确认"
        },
        {
          "object": "`matrix` 表格",
          "summary": "**默认展示判断**，证据按需展开。",
          "risk": {
            "badge": "Medium",
            "tone": "warning"
          },
          "evidence": {
            "summary": "Markdown 宽表容易丢列上下文。",
            "detail": "固定表头和首列后，读者滚动时仍能确认对象和维度。"
          },
          "confidence": {
            "progress": 86,
            "label": "足够稳定"
          },
          "next": [
            "freeze",
            "search",
            "tags"
          ],
          "details": "适合方案比较、风险表、PR review、排期表、需求矩阵。"
        },
        {
          "object": "`motionStage` 动画",
          "summary": "只在状态变化能直观看懂时使用。",
          "risk": {
            "badge": "Low",
            "tone": "success"
          },
          "evidence": {
            "summary": "对象位置、显隐、状态和数值发生变化。",
            "detail": "字幕只做补充，主信息应该出现在画面变化里。"
          },
          "confidence": {
            "score": 78,
            "label": "可复用"
          },
          "next": {
            "badge": "demo",
            "tone": "accent"
          }
        },
        {
          "group": "可以后置"
        },
        {
          "object": "长正文",
          "summary": "拆成卡片、矩阵、批注或展开材料。",
          "risk": {
            "badge": "High",
            "tone": "danger"
          },
          "evidence": {
            "summary": "连续段落会让读者反复重建结构。",
            "detail": "如果内容需要比较、优先级、关系或状态，就改用视觉组件。"
          },
          "confidence": {
            "progress": 92,
            "label": "明确"
          },
          "next": {
            "badge": "split",
            "tone": "info"
          }
        }
      ]
